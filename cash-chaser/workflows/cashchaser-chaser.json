      "parameters": {
        "jsCode": "const tierLevel = { friendly: 1, firm: 2, final: 3 };\n\nlet ledger = [];\ntry { ledger = $('Get chases').all().map(i => i.json); } catch (e) {}\nconst byId = {};\nfor (const row of ledger) { if (row.invoice_id) byId[row.invoice_id] = row; }\n\nconst results = [];\nfor (const item of $('Tier invoices').all()) {\n  const inv = item.json;\n  const level = tierLevel[inv.tier];\n  const existing = byId[inv.invoiceId];\n\n  let shouldSend = false;\n  if (!existing) shouldSend = true;                                   // never chased\n  else if (String(existing.status).toUpperCase() === 'CLOSED') shouldSend = false;\n  else if (level > Number(existing.level || 0)) shouldSend = true;    // escalation only\n\n  if (shouldSend) results.push({ json: { ...inv, level } });\n}\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
