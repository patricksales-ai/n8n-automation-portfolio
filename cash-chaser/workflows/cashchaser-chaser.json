      "parameters": {
        "jsCode": "const today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  const inv = item.json;\n\n  // only unpaid, approved invoices\n  if (inv.Status !== 'AUTHORISED') continue;\n  if (!(inv.AmountDue > 0)) continue;\n  if (!inv.DueDateString) continue;\n\n  const due = new Date(inv.DueDateString);\n  due.setHours(0, 0, 0, 0);\n\n  const daysOverdue = Math.floor((today - due) / 86400000);\n  if (daysOverdue <= 0) continue; // not overdue yet\n\n  // tone-ladder tier\n  let tier;\n  if (daysOverdue >= 30) tier = 'final';   // 30d+\n  else if (daysOverdue >= 14) tier = 'firm';   // 14–29d\n  else if (daysOverdue >= 7) tier = 'friendly'; // 7–13d\n  else continue; // 1–6d overdue: too soon to chase\n\n  results.push({\n    json: {\n      invoiceId: inv.InvoiceID,\n      invoiceNumber: inv.InvoiceNumber,\n      amountDue: inv.AmountDue,\n      currency: inv.CurrencyCode,\n      dueDate: inv.DueDateString.substring(0, 10),\n      daysOverdue,\n      tier,\n      contactId: inv.Contact?.ContactID,\n      contactName: inv.Contact?.Name,\n    },\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        0
      ],
      "id": "30aff4a2-ea9d-4079-8007-33637b155c84",
      "name": "Tier invoices"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "role": "system",
              "content": "=You are the accounts-receivable assistant for Demo Company, writing payment-reminder emails to customers. Return ONLY a JSON object with exactly two keys: \"subject\" and \"body\". \"body\" is plain text (no markdown), 90–140 words, signed off from \"The Demo Company Accounts Team\". Never invent facts beyond those provided; use the exact invoice number, amount, and due date given. Match tone strictly to the tier:\n- friendly: warm and appreciative, a gentle nudge, assume good faith.\n- firm: professional and direct, a clear request to pay now, reference how overdue it is.\n- final: serious, state this is a final reminder before the account may be escalated, remain professional and non-threatening."
            },
            {
              "content": "=Tier: {{ $json.tier }}\nCustomer: {{ $json.contactName }}\nInvoice number: {{ $json.invoiceNumber }}\nAmount due: {{ $json.currency }} {{ $json.amountDue }}\nDue date: {{ $json.dueDate }}\nDays overdue: {{ $json.daysOverdue }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {
