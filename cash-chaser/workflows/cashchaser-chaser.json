      "parameters": {
        "jsCode": "const senders = $('Decide sends').all();\nconst items = $input.all();\nconst results = [];\nfor (let i = 0; i < items.length; i++) {\n  const out = items[i].json.output?.[0]?.content?.[0]?.text;\n  let parsed = (out && typeof out === 'object') ? out\n    : (typeof out === 'string' ? (()=>{try{return JSON.parse(out)}catch(e){return {subject:'(parse failed)',body:out}}})()\n    : { subject:'(no output)', body:'' });\n  results.push({ json: { ...senders[i].json, subject: parsed.subject, body: parsed.body } });\n}\nreturn results;"
      },
