      "parameters": {
        "jsCode": "const invoices = {};\nfor (const it of $('Get many invoices').all()) invoices[it.json.InvoiceID] = it.json;\n\nconst seen = new Set();\nconst results = [];\nfor (const it of $('Get chases').all()) {\n  const row = it.json;\n  if (String(row.status).toUpperCase() !== 'OPEN') continue;\n  if (seen.has(row.invoice_id)) continue;\n  const inv = invoices[row.invoice_id];\n  const paid = inv && (inv.Status === 'PAID' || Number(inv.AmountDue) === 0);\n  if (paid) {\n    seen.add(row.invoice_id);\n    results.push({ json: { invoiceNumber: row.invoice_number, contactName: row.contact, invoiceId: row.invoice_id } });\n  }\n}\nreturn results;"
      },
