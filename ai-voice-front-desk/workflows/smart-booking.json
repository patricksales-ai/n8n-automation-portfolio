      {
        "parameters": {
          "jsCode": "// Pick First Free — walk candidates in round-robin order, take the first FREE one.\nconst candidates = $('Build Candidates').all();  // 3 items in preference order\nconst checks     = $input.all();                 // Get Availability output, same order\n\nlet chosen = null;\nfor (let i = 0; i < candidates.length; i++) {\n  if (checks[i].json.available === true) { chosen = candidates[i].json; break; }\n}\n\nconst first = candidates[0].json;\n\nif (!chosen) {                                    // all three busy\n  return [{ json: {\n    booked: false,\n    response: 'Sorry, all our stylists are booked at that time. Could you try another time?',\n    name: first.name, service: first.service, startTime: first.startTime,\n  }}];\n}\n\nreturn [{ json: {                                 // a free stylist was found\n  booked: true,\n  stylistName: chosen.stylistName,\n  calendarId:  chosen.calendarId,\n  name:        chosen.name,\n  service:     chosen.service,\n  startTime:   chosen.startTime,\n  endTime:     chosen.endTime,\n}}];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -720,
          16
        ],
        "id": "9c01c426-3322-4538-a3a7-1a40f42956c1",
        "name": "Pick First Free"
