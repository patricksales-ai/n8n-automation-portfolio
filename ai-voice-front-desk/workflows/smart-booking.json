            "name": "Twilio account"
          }
        },
        "onError": "continueRegularOutput"
      },
      {
        "parameters": {
          "jsCode": "// Build Candidates — round-robin order, reading booking details from the webhook body.\nconst body = $('Booking Webhook').first().json.body;\nconst name = body.name;\nconst service = body.service;\n\nconst start   = DateTime.fromISO(body.startTime, { zone: 'Asia/Manila' });\nconst startISO = start.toISO();\nconst endISO   = start.plus({ minutes: 30 }).toISO();\n\nconst realRows = $input.all().filter(i => i.json && i.json.Name);\nconst idx = realRows.length % 3;\n\nconst stylists = [\n  { stylistName: 'Stylist A', calendarId: 'bdd7ff6246bda16dc8858e022cbd22ce43fb2bcf5934c69fd298c25e08d392dc@group.calendar.google.com' },\n  { stylistName: 'Stylist B', calendarId: 'bb0915931df59c658f62a1cd22d7906ad0fe1fcddc5a10a27abd39514214ccb8@group.calendar.google.com' },\n  { stylistName: 'Stylist C', calendarId: '3b5a30cfd028461b373be9a685b1e255b0898de55d3b227b85053c3c7655dab7@group.calendar.google.com' },\n];\n\nreturn [0, 1, 2].map((offset) => {\n  const s = stylists[(idx + offset) % 3];\n  return {\n    json: {\n      preference: offset, stylistName: s.stylistName, calendarId: s.calendarId,\n      name, service, startTime: startISO, endTime: endISO,\n    },\n  };\n});"
        },
        "type": "n8n-nodes-base.code",
