      "name": "Respond to Webhook"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.body.SpeechResult }}",
        "options": {
          "systemMessage": "=When a caller wants to book, first collect their name, the service, and a specific date and time.\nBefore booking, repeat the name, service, date and time back to the caller and get an explicit \"yes\".\nOnly call book_appointment after they confirm.\nIf book_appointment reports that all stylists are booked, apologize and ask the caller for a different time.\nAfter a successful booking, read the confirmation back to the caller.\n\nIf the caller asks to speak to a human, a person, an agent, a receptionist, the front desk, or a manager — or is clearly upset and wants a real person — your ENTIRE reply must be exactly <<TRANSFER>> and nothing else. Do not add any other words."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
