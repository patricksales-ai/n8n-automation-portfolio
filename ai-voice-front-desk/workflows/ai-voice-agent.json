        "jsonBody": "={{ JSON.stringify({ name: $fromAI('name', 'the caller full name'), service: $fromAI('service', 'service requested, e.g. haircut'), startTime: $fromAI('startTime', 'ISO 8601 datetime with Manila +08:00 offset'), phone: $('Webhook').item.json.body.From }) }}",
