    {
      "parameters": {
        "text": "=Subject: {{ $json.subject }}\n\nFrom: {{ $json.fromRaw }}\n\n{{ $json.body }}",
        "attributes": {
          "attributes": [
            {
              "name": "is_lead",
              "type": "boolean",
              "description": "true if a genuine sales/business inquiry; false if spam, newsletter, job app, or vendor pitch"
            },
            {
              "name": "name",
              "description": "sender's full name, or \"unknown\""
            },
            {
              "name": "company",
              "description": "sender's company, or \"unknown\""
            },
            {
              "name": "budget",
              "description": "stated budget, or \"unknown\""
            },
            {
              "name": "authority",
              "description": "sender's decision-making role, or \"unknown\""
            },
            {
              "name": "need",
              "description": "the problem/need they described"
            },
            {
              "name": "timeline",
              "description": "when they want to start, or \"unknown\""
            },
            {
              "name": "score",
              "type": "number",
              "description": "BANT fit, 0–100"
            },
            {
              "name": "stage",
              "description": "exactly one of: qualified, not_qualified, unclear"
            },
            {
              "name": "summary",
              "description": "one-sentence summary of the lead"
            }
          ]
        },
        "options": {
          "systemPromptTemplate": "=You are a B2B sales lead qualifier. Read the inbound email and assess it with the BANT framework (Budget, Authority, Need, Timeline). Extract the sender's details and score the lead 0–100.\n\nScoring (25 points each):\n- Budget: a clear, sufficient budget is stated = full; vague/partial = some; none = 0.\n- Authority: sender is a decision-maker (founder, owner, C-level, \"my call to make\") = full; influencer = partial; unknown = 0.\n- Need: a clear, specific problem your service solves = full; vague curiosity = partial.\n- Timeline: wants to act soon (within ~1 month) = full; later = partial; none = 0.\n\nSet stage:\n- \"qualified\"      -> is_lead is true AND score >= 60\n- \"unclear\"        -> a real inquiry but too little info (score 30–59)\n- \"not_qualified\"  -> not a genuine buying inquiry (spam, newsletter, job application, vendor pitch) or very low score\n\nis_lead = true ONLY for genuine business/sales inquiries.\nFor any field the email does not state, return the literal string \"unknown\" — never invent a value, and never output the word \"undefined\".\nsummary = one short sentence."
        }
      },
