          "cachedResultName": "all-n8n-portfolio"
        },
        "text": "=🔧 *New task from {{ $('Normalize').item.json.output.client }}*  ({{ $('Edit Fields').item.json.client_phone }})\n\n*{{ $('Normalize').item.json.output.title }}*  ·  priority: {{ $('Normalize').item.json.output.priority }}  ·  type: {{ $('Normalize').item.json.output.type }}\n\n{{ $('Normalize').item.json.output.summary }}",
        "otherOptions": {}
      },
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.5,
      "position": [
        1328,
        -64
      ],
      "id": "34b33bc6-734e-4caa-bc59-76b02ce0e7f0",
      "name": "Send a message",
      "webhookId": "66679211-2bf3-4777-868a-7cb16abc2098",
      "credentials": {
        "slackApi": {
          "id": "1OmcAA2AKHVVunVC",
          "name": "Slack account"
        }
      }
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a task-extraction assistant for a marketing agency. A client sent this WhatsApp message. Extract a structured task from it.\n\nClient name: {{ $json.client_name }}\nClient phone: {{ $json.client_phone }}\nMessage type: {{ $json.msg_type }}\nMessage: {{ $json.text }}\n\nRules:\n- is_task: true if this is a real actionable request. false for chit-chat/acknowledgements (\"ok\", \"thanks\", \"got it\").\n- title: short imperative task title, max 8 words.\n- client: the COMPANY name only, stripped of any personal name. E.g. from \"Mike - Apex Roofing\" return \"Apex Roofing\".\n- type: one of \"task\", \"question\", \"urgent\", \"other\".\n- priority: exactly one of \"High\", \"Medium\", or \"Low\". Use \"High\" if a deadline is near or urgency words are used; \"Low\" for FYI/no action needed; \"Medium\" otherwise.\n- summary: 1-2 sentences including any budget, deadline, or targeting details.\n\nRespond ONLY with json in exactly this shape:\n{\"output\":{\"is_task\":true,\"title\":\"\",\"client\":\"\",\"type\":\"task\",\"priority\":\"Medium\",\"summary\":\"\"}}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        336,
        0
      ],
      "id": "2dc121f5-c387-4586-8bf5-f2b523a2c140",
      "name": "Basic LLM Chain"
    },
    {
      "parameters": {
        "jsCode": "const j = $input.item.json;\nlet o = typeof j.text === 'string'\n  ? JSON.parse(j.text.replace(/```json\\s*/gi, '').replace(/```/g, '').trim())\n  : j;\nif (!o.output) o = { output: o };\nreturn { json: o };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        0
      ],
      "id": "a56dcf46-272b-465d-bc64-d9b944510a52",
      "name": "Normalize"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "5e5664a9-77cc-4cac-b871-eb8c410633f3",
              "leftValue": "={{ $json.output.is_task }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        896,
        0
      ],
      "id": "fa887dbf-65da-498e-9d8f-4696d5de0f22",
      "name": "If"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.monday.com/v2",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"query\": \"mutation ($board: ID!, $name: String!, $cols: JSON!) { create_item (board_id: $board, item_name: $name, column_values: $cols, create_labels_if_missing: true) { id name } }\",\n  \"variables\": {\n    \"board\": \"YOUR_MONDAY_BOARD_ID\",\n    \"name\": $('Normalize').item.json.output.title,\n    \"cols\": JSON.stringify({\n      \"project_status\": { \"label\": \"New\" },\n      \"priority\": { \"label\": $('Normalize').item.json.output.priority },\n      \"text\": $('Normalize').item.json.output.summary,\n      \"text_mm5avj0\": $('Normalize').item.json.output.client,\n      \"text_mm5ava7h\": $('Normalize').item.json.output.type\n    })\n  }\n} }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
