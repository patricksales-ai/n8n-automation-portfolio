    {
      "parameters": {
        "text": "=Subject: {{ $json.subject }}\nBody: {{ $json.text }}",
        "attributes": {
          "attributes": [
            {
              "name": "is_lead",
              "type": "boolean",
              "description": "true if a possible sales lead (complete, partial, or inquiry); false only for clearly non-sales mail."
            },
            {
              "name": "confidence",
              "type": "number",
              "description": "0–100 confidence in the is_lead decision"
            },
            {
              "name": "reason",
              "description": "One sentence justifying the decision."
            },
            {
              "name": "lead_temperature",
              "description": "hot / warm / cold; \"none\" if not a lead."
            },
            {
              "name": "contact_name",
              "description": "Lead's full name; \"\" if unknown."
            },
            {
              "name": "company_name",
              "description": "\tCompany; infer from business email domain if blank; \"\" if none."
            },
            {
              "name": "contact_email",
              "description": "Lead's email from the body/signature; \"\" if none."
            },
            {
              "name": "phone",
              "description": "Phone from the body; \"\" if none."
            },
            {
              "name": "intent",
              "description": "Short phrase for what they want."
            },
            {
              "name": "summary",
              "description": "One sentence about the lead."
            },
            {
              "name": "data_quality_score",
              "type": "number",
              "description": "0–100 completeness of the lead info."
            }
          ]
        },
        "options": {
          "systemPromptTemplate": "=You are a senior SDR triaging an inbound email inbox. For each email you must\n(a) decide if it is a POSSIBLE SALES LEAD, and (b) if so, extract the lead's details.\n\nis_lead = true when a real person shows genuine interest in a business's product or\nservice — in ANY form: complete details, partial details, or just an inquiry\n(\"Do you offer X?\", \"How much?\", \"Can I get a demo/quote?\"). Treat missing info as a\ndata-quality issue, NEVER a reason to reject. When genuinely ambiguous, choose true.\n\nis_lead = false ONLY for clearly non-sales mail: newsletters, marketing blasts,\npromotions, receipts/invoices, shipping/order notices, password resets, security\nalerts, calendar invites, social notifications, out-of-office replies, spam, and\ninternal or personal messages.\n\nIMPORTANT: If the email is our OWN outbound acknowledgment — it thanks the recipient\nfor reaching out, says a team member will follow up, and is signed \"The Team\" — set\nis_lead = false. Never treat our own sent replies as leads.\n\nIf is_lead is false, set lead_temperature to \"none\" and leave contact fields \"\".\n\nWhen is_lead is true:\n- Pull name, company, email, phone from the body/signature; use \"\" for anything missing.\n  The lead's real email is usually in the body, not the envelope sender.\n- lead_temperature: hot = explicit buying signal (demo/quote/pricing/urgent);\n  warm = interested/exploring/asking; cold = vague or info-gathering only.\n- intent: one short phrase for what they want.\n- summary: one sentence describing the lead.\n- data_quality_score: score the ORIGINAL email's completeness. Start at 0 and add:\n  +25 full name, +25 identifiable company, +20 business (non-personal) email,\n  +15 phone number, +15 job title/role. Cap at 100. (Fully-detailed lead ≈ 100;\n  a name + email with nothing else ≈ 45.)\n- confidence: 0-100 for how sure you are about is_lead.\n- reason: one sentence justifying the is_lead decision.\nNever invent facts. Infer company from the email domain only if it is a business domain."
        }
      },
