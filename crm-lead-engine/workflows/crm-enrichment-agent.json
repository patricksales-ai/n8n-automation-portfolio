    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://api.hubapi.com/crm/v3/objects/contacts/{{ $('Normalize').first().json.id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"properties\": {\n    \"ai_summary\": \"{{ $('Information Extractor').first().json.output.summary }}\",\n    \"ai_segment\": \"{{ $('Information Extractor').first().json.output.segment }}\",\n    \"ai_industry\": \"{{ $('Information Extractor').first().json.output.industry }}\",\n    \"ai_seniority\": \"{{ $('Information Extractor').first().json.output.seniority }}\",\n    \"ai_company_domain\": \"{{ $('Information Extractor').first().json.output.company_domain }}\",\n    \"data_quality_score\": \"{{ $('Information Extractor').first().json.output.data_quality_score }}\",\n    \"ai_enriched\": \"true\"\n  }\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1824,
        -144
      ],
      "id": "6406aa2e-1ae6-462b-a3f6-a3d0bac9b60b",
      "name": "HubSpot Update",
      "credentials": {
        "hubspotOAuth2Api": {
          "id": "REPLACE_WITH_YOUR_HUBSPOT_CREDENTIAL",
          "name": "REPLACE_WITH_YOUR_HUBSPOT_CREDENTIAL"
        },
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_YOUR_HUBSPOT_TOKEN_CREDENTIAL",
          "name": "REPLACE_WITH_YOUR_HUBSPOT_TOKEN_CREDENTIAL"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst count = items.length;\nlet scoreSum = 0;\nconst seniority = {};\nfor (const it of items) {\n  const p = it.json.properties || {};\n  scoreSum += Number(p.data_quality_score) || 0;\n  const sen = p.ai_seniority || 'unknown';\n  seniority[sen] = (seniority[sen] || 0) + 1;\n}\nconst avgScore = count ? Math.round(scoreSum / count) : 0;\nconst segLine = Object.entries(seniority).sort((a, b) => b[1] - a[1]).map(([k, v]) => `${k}: ${v}`).join(', ') || 'none';\nreturn [{ json: { count, avgScore, segLine } }];"
      },
