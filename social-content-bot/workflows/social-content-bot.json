      "parameters": {
        "promptType": "define",
        "text": "=Improve these draft posts:\n\n{{ JSON.stringify($json.output) }}",
        "messages": {
          "messageValues": [
            {
              "message": "=You are a ruthless social media editor. You receive draft posts for LinkedIn, X,\nand Instagram. For each one, silently score it 1-10 on (a) hook strength,\n(b) clarity, (c) on-brand voice — sharp, honest, encouraging. Then rewrite each\npost to fix its single weakest dimension, while keeping that platform's length\nlimit and norms (LinkedIn <=1200, X <=270, Instagram caption <=300, 5-10 tags).\n\nDo not add fabricated stats or quotes. Return only the improved posts in the same\nJSON structure (linkedin, x, instagram). No scores, no commentary."
            }
          ]
        },
        "batching": {}
