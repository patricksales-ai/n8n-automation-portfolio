    {
      "parameters": {
        "jsCode": "const j = $input.item.json;\nlet obj;\nif (typeof j.text === 'string') {\n  // Cloud / string case: parse the JSON string\n  const s = j.text.replace(/```json\\s*/gi, '').replace(/```/g, '').trim();\n  obj = JSON.parse(s.slice(s.indexOf('{'), s.lastIndexOf('}') + 1));\n} else {\n  obj = j;                       // self-host case: already a parsed object\n}\nif (!obj.output) obj = { output: obj };   // force consistent {output:{…}} shape\nreturn { json: obj };"
      },
      "type": "n8n-nodes-base.code",
