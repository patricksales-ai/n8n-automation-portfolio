      {
        "parameters": {
          "sendTo": "you@example.com",
          "subject": "={{ 'New lead [' + $json.outcome_tag.toUpperCase() + '] — ' + $json.opportunity_product }}",
          "message": "={{ (() => {\n  const tag = ($json.outcome_tag || '').toLowerCase();\n  const color = tag==='hot' ? '#e11d48' : tag==='warm' ? '#f59e0b' : tag==='future' ? '#3b82f6' : '#64748b';\n  const row = (l,v) => `<tr><td style=\"padding:5px 0;color:#64748b;font-size:13px;width:120px;\">${l}</td><td style=\"padding:5px 0;color:#0f172a;font-size:14px;font-weight:600;\">${v || '—'}</td></tr>`;\n  const label = (t) => `<div style=\"font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin:20px 0 6px;font-weight:700;\">${t}</div>`;\n  return `\n<div style=\"font-family:-apple-system,Segoe UI,Roboto,Arial,sans-serif;max-width:600px;margin:0 auto;background:#f1f5f9;padding:20px;\">\n  <div style=\"background:#fff;border-radius:12px;border:1px solid #e2e8f0;overflow:hidden;\">\n    <div style=\"background:${color};padding:18px 24px;\">\n      <div style=\"color:#fff;font-size:11px;letter-spacing:2px;text-transform:uppercase;opacity:.9;\">New Lead</div>\n      <div style=\"color:#fff;font-size:22px;font-weight:800;margin-top:2px;\">${($json.outcome_tag||'').toUpperCase()} &nbsp;·&nbsp; ${$json.sentiment||''}</div>\n    </div>\n    <div style=\"padding:8px 24px 20px;\">\n      ${label('Opportunity')}\n      <table style=\"width:100%;border-collapse:collapse;\">\n        ${row('Product',$json.opportunity_product)}\n        ${row('Quantity',$json.opportunity_quantity)}\n        ${row('Budget',$json.opportunity_budget)}\n        ${row('Timeframe',$json.opportunity_timeframe)}\n        ${row('Location',$json.opportunity_location)}\n        ${row('Follow-up',$json.opportunity_follow_up_method)}\n      </table>\n      ${label('Rep')}\n      <table style=\"width:100%;border-collapse:collapse;\">\n        ${row('Prior rep',$json.prior_rep)}\n        ${row('Wants follow-up',$json.rep_follow_up ? 'Yes' : 'No')}\n      </table>\n      ${label('Summary')}\n      <div style=\"font-size:14px;color:#334155;line-height:1.6;\">${$json.summary||''}</div>\n      <div style=\"margin:22px 0 4px;\">\n        <a href=\"${$json.recording_url}\" style=\"display:inline-block;background:#0f172a;color:#fff;text-decoration:none;font-size:13px;font-weight:600;padding:11px 20px;border-radius:8px;\">▶ Play recording</a>\n      </div>\n      ${label('Transcript')}\n      <div style=\"white-space:pre-wrap;font-size:12px;color:#475569;line-height:1.55;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:14px;\">${$json.transcript||''}</div>\n    </div>\n  </div>\n</div>` })() }}",
          "options": {
            "appendAttribution": false
          }
        },
