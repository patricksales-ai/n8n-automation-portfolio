      {
        "parameters": {
          "jsCode": "const call = $input.first().json;\n\n// structuredOutputs live under artifact for web calls — check there first\nconst so = call.artifact?.structuredOutputs || call.structuredOutputs || call.analysis?.structuredOutputs || {};\n// grab the first (only) output's result, no UUID hardcoding\nconst a = Object.values(so)[0]?.result || {};\n\nreturn [{\n  json: {\n    // --- call metadata ---\n    call_id:         call.id || '',\n    ended_at:        call.endedAt || '',\n    ended_reason:    call.endedReason || '',\n    customer_number: call.customer?.number || '',\n    recording_url:   call.recordingUrl || call.artifact?.recordingUrl || '',\n    transcript:      call.transcript || call.artifact?.transcript || '',\n    cost:            call.cost || '',\n    // --- call_analysis (flattened) ---\n    contact_confirmed:            a.contact_confirmed ?? '',\n    sentiment:                    a.sentiment || '',\n    needs:                        a.needs || '',\n    opportunity_product:          a.opportunity_product || '',\n    opportunity_quantity:         a.opportunity_quantity || '',\n    opportunity_budget:           a.opportunity_budget || '',\n    opportunity_timeframe:        a.opportunity_timeframe || '',\n    opportunity_location:         a.opportunity_location || '',\n    opportunity_follow_up_method: a.opportunity_follow_up_method || '',\n    prior_rep:                    a.prior_rep || '',\n    rep_follow_up:                a.rep_follow_up ?? '',\n    outcome_tag:                  a.outcome_tag || '',\n    opt_out:                      a.opt_out ?? '',\n    summary:                      a.summary || ''\n  }\n}];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
