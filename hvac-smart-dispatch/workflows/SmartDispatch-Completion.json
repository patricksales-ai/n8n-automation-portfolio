          "id": "yMqkk4M0kF50KIC0",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const job  = $input.first().json;\nconst comp = $('Normalize').first().json.output;\n\nconst BASE = 800;\nconst URGENCY_PREMIUM = {\n  'Emergency':  1500,\n  'Within-24h':  500,\n  'This-week':     0,\n};\n\nconst premium = URGENCY_PREMIUM[job.urgency] ?? 0;\nconst parts   = Number(comp.parts_cost) || 0;\nconst total   = BASE + premium + parts;\n\nreturn [{\n  json: {\n    job_id:           job.job_id,\n    customer:         job.customer,\n    customer_email:   job.customer_email,\n    contact:          job.contact,\n    address:          job.address,\n    issue:            job.issue,\n    urgency:          job.urgency,\n    assigned_tech:    job.assigned_tech,\n    completion_notes: comp.completion_notes,\n    parts_used:       comp.parts_used,\n    base:             BASE,\n    urgency_premium:  premium,\n    parts_cost:       parts,\n    total:            total,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        976,
        0
      ],
      "id": "8e77e5d6-8bf2-483d-886c-4c886b2d2b64",
      "name": "Price calc"
    },
    {
      "parameters": {
        "sendTo": "={{ $('Price calc').first().json.customer_email || 'you@example.com' }}",
        "subject": "=Your SmartDispatch invoice - PHP {{ $('Price calc').first().json.total }}",
        "message": "=<p>Hi {{ $('Price calc').first().json.customer }},</p>\n\n<p>Your service is complete. Here is your invoice.</p>\n\n<p>\n<strong>Job:</strong> {{ $('Price calc').first().json.issue }}<br>\n<strong>Technician:</strong> {{ $('Price calc').first().json.assigned_tech }}<br>\n<strong>Work done:</strong> {{ $('Price calc').first().json.completion_notes }}\n</p>\n\n<table cellpadding=\"6\" style=\"border-collapse:collapse; font-family:Arial,sans-serif;\">\n  <tr><td>Call-out fee</td><td style=\"text-align:right;\">PHP {{ $('Price calc').first().json.base }}</td></tr>\n  <tr><td>Urgency ({{ $('Price calc').first().json.urgency }})</td><td style=\"text-align:right;\">PHP {{ $('Price calc').first().json.urgency_premium }}</td></tr>\n  <tr><td>Parts ({{ $('Price calc').first().json.parts_used }})</td><td style=\"text-align:right;\">PHP {{ $('Price calc').first().json.parts_cost }}</td></tr>\n  <tr>\n    <td style=\"border-top:2px solid #333;\"><strong>Total due</strong></td>\n    <td style=\"border-top:2px solid #333; text-align:right;\"><strong>PHP {{ $('Price calc').first().json.total }}</strong></td>\n  </tr>\n</table>\n\n<p style=\"color:#888; font-size:12px;\">Job ref: {{ $('Price calc').first().json.job_id }}</p>\n\n<p>Thank you for choosing SmartDispatch.</p>",
        "options": {
          "appendAttribution": false
        }
      },
