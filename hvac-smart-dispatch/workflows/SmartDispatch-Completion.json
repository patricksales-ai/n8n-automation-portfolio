      ],
      "id": "e4e9705a-0df4-42a1-a904-508ae8f6d70c",
      "name": "When chat message received",
      "webhookId": "871a6df6-0161-4d34-bb48-173fbc73024a"
    },
    {
      "parameters": {
        "messages": {
          "messageValues": [
            {
              "message": "=You are a dispatch completion parser for an HVAC field-service company.\nA technician sends a short message when they finish a job. Extract the job details as JSON.\n\nReturn ONLY this JSON shape:\n{\n  \"customer_name\": \"the customer the job was for, or empty string if not stated\",\n  \"completion_notes\": \"what the tech did, one short sentence\",\n  \"parts_used\": \"parts replaced/installed, or empty string if none\",\n  \"parts_cost\": 0\n}\n\nRules:\n- parts_cost is a NUMBER in pesos (no currency symbol, no commas). If the tech gives a parts price, use it. If no parts, 0.\n- customer_name is the person's name only (e.g. \"Ana\"), not the appliance.\n- Never invent a price. If unstated, parts_cost = 0."
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        208,
        0
      ],
      "id": "46a4927c-8f1b-4c0f-989e-07a8297c8531",
      "name": "Basic LLM Chain"
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "gpt-4o-mini"
        },
        "builtInTools": {},
        "options": {
          "textFormat": {
            "textOptions": {
              "type": "json_object"
            }
          }
        }
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        144,
        208
      ],
      "id": "7c69ce2e-f40e-4b68-8411-03393eed82b3",
      "name": "OpenAI Chat Model",
      "credentials": {
