    {
      "parameters": {
        "jsCode": "// Basic LLM Chain returns the model's text; parse it to a clean object.\nconst raw = $input.first().json;\nlet out = raw.output ?? raw.text ?? raw;\nif (typeof out === 'string') {\n  out = JSON.parse(out.replace(/```json|```/g, '').trim());\n}\nreturn [{ json: { output: out } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        0
      ],
      "id": "794cee9c-b283-4d94-afd1-531526853375",
      "name": "Normalize"
    },
    {
