    {
      "parameters": {
        "jsCode": "const cal = $input.all();\nconst candidates = $('matcher').all().map(c => c.json);\n\n// Case A: matcher found nobody with the right area+skill\nif (candidates.length === 1 && candidates[0]._noMatch) {\n  return [{ json: { _escalate: true, _reason: 'no_match', job: candidates[0].job } }];\n}\n\n// Mark a candidate busy if the calendar returned a real event for it\nconst busy = {};\nfor (const item of cal) {\n  const idx = item.pairedItem?.item ?? item.pairedItem ?? 0;\n  if (item.json && item.json.id) busy[idx] = true;   // a real event = booked\n}\n\n// Case B: return the first candidate with no conflicting event\nfor (let i = 0; i < candidates.length; i++) {\n  if (!busy[i]) return [{ json: { ...candidates[i], _escalate: false } }];\n}\n\n// Case C: candidates existed but every one is busy\nreturn [{ json: { _escalate: true, _reason: 'all_busy', job: candidates[0].job } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        512,
        0
      ],
      "id": "0b896444-63c5-4818-90b4-320c0380f8a7",
      "name": "Pick first free"
    },
    {
      "parameters": {
        "jsCode": "const job = $('Normalize').first().json.output;\n\nconst norm = (s) => String(s ?? '')\n  .split(',')\n  .map(v => v.trim().toLowerCase())\n  .filter(Boolean);\n\nconst jobArea  = String(job.address ?? '').toLowerCase();\nconst jobSkill = String(job.skill_required ?? '').toLowerCase();\n\nconst candidates = $input.all()\n  .map(item => {\n    const t = item.json;\n    const areas  = norm(t.areas);\n    const skills = norm(t.skills);\n    const areaMatch  = areas.some(a => jobArea.includes(a));\n    const skillMatch = skills.includes(jobSkill);\n    const score = (areaMatch ? 1 : 0) + (skillMatch ? 1 : 0);\n    return { json: { ...t, _areaMatch: areaMatch, _skillMatch: skillMatch, _score: score, job } };\n  })\n  .filter(c => c.json._areaMatch && c.json._skillMatch)\n  .sort((a, b) => b.json._score - a.json._score);\n\nif (candidates.length === 0) {\n  // no area+skill match — emit a marker so the chain keeps flowing.\n  // calendar_id = your primary calendar just to keep the Calendar node happy;\n  // Pick first free ignores the calendar result for markers.\n  return [{ json: { _noMatch: true, job, calendar_id: 'you@example.com' } }];\n}\nreturn candidates;"
      },
